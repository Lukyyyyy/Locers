{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Locers",
  "version": "0.1.0",
  "identifier": "com.locers.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Locers",
        "width": 1280,
        "height": 840,
        "minWidth": 1240,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
